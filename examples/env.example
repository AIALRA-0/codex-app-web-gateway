# Public HTTP listener for the login proxy.
CODEXAPP_HOST=0.0.0.0
CODEXAPP_PORT=8080

# Internal webview bridge listener.
CODEXAPP_WEB_HOST=127.0.0.1
CODEXAPP_WEB_PORT=12910
CODEXAPP_UPSTREAM=http://127.0.0.1:12910

# Required login settings. Replace all values before deployment.
CODEXAPP_USERNAME=admin@example.com
CODEXAPP_PASSWORD=change-me
CODEXAPP_SESSION_SECRET=replace-with-at-least-32-random-bytes

# Codex runtime state. Mount this path as persistent storage.
CODEX_HOME=/data/codex-home
CODEXAPP_STATE_DIR=/data/state

# Codex Desktop webview assets extracted by scripts/prepare-webview.sh or baked into Docker.
CODEXAPP_WEBVIEW_DIR=/opt/codex-app-web-gateway/webview

# Codex CLI path inside the container or host.
CODEXAPP_CODEX_CLI=codex

# Optional UI labels.
CODEXAPP_LOGIN_APP_NAME=Codex App
CODEXAPP_LOGIN_SUBTITLE=Sign in to continue to your self-hosted Codex workspace.

# Optional private account-provider hook. The provider is not included in this repo.
# CODEXAPP_AUTO_ACCOUNT_SWITCH=1
# CODEXAPP_ACCOUNT_PROVIDER_URL=http://account-provider:9000
# CODEXAPP_ACCOUNT_PROVIDER_TOKEN=replace-with-a-private-token
# CODEXAPP_ACCOUNT_PROVIDER_TIMEOUT_MS=15000
# CODEXAPP_ACCOUNT_SWITCH_SETTLE_MS=1500
# CODEXAPP_ACCOUNT_SWITCH_MIN_INTERVAL_MS=15000
# CODEXAPP_ACCOUNT_SWITCH_FORCE_RELOAD=0

# Optional build-time webview source override.
# CODEX_DESKTOP_APP_VERSION=26.506.31421
# CODEX_DESKTOP_ARCHIVE_URL=https://persistent.oaistatic.com/codex-app-prod/Codex-darwin-arm64-26.506.31421.zip
