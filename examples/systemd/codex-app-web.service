[Unit]
Description=Codex App Web Gateway bridge
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=codex
Group=codex
WorkingDirectory=/opt/codex-app-web-gateway
EnvironmentFile=/etc/codex-app-web-gateway.env
ExecStart=/usr/bin/node /opt/codex-app-web-gateway/src/web-server.js
Restart=always
RestartSec=3
LimitNOFILE=65535

[Install]
WantedBy=multi-user.target
