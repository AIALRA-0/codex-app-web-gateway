[Unit]
Description=Codex App Web Gateway login proxy
After=network-online.target codex-app-web.service
Wants=network-online.target
Requires=codex-app-web.service

[Service]
Type=simple
User=codex
Group=codex
WorkingDirectory=/opt/codex-app-web-gateway
EnvironmentFile=/etc/codex-app-web-gateway.env
ExecStart=/usr/bin/node /opt/codex-app-web-gateway/src/login-proxy.js
Restart=always
RestartSec=3
LimitNOFILE=65535

[Install]
WantedBy=multi-user.target
